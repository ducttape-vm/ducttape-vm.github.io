{"version": 2, "width": 80, "height": 24, "timestamp": 1782624932, "env": {"SHELL": "/usr/bin/zsh", "TERM": null}, "title": "Ducttape: Container vs VM"}
[0.001574, "o", "\r\n=== Ducttape: Container vs VM comparison ===\r\n\r\n"]
[0.002194, "o", "$ # 1. Build and run the Containerfile with Podman\r\n\r\n$ cat ~/Projects/machinefile/examples/ubuntu-claude/Containerfile\r\n"]
[0.002696, "o", "FROM ubuntu:26.04\r\n\r\nENV DEBIAN_FRONTEND=noninteractive\r\nENV DISABLE_AUTOUPDATER=true\r\n\r\nRUN apt-get update && apt-get install -y \\\r\n    curl \\\r\n    git \\\r\n    build-essential \\\r\n    ca-certificates \\\r\n    && rm -rf /var/lib/apt/lists/*\r\n\r\nRUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \\\r\n    && apt-get install -y nodejs \\\r\n    && rm -rf /var/lib/apt/lists/*\r\n\r\nRUN npm install -g @anthropic-ai/claude-code\r\n\r\nWORKDIR /workspace\r\n\r\n"]
[0.00275, "o", "\r\n$ podman build -t ubuntu-claude -f ~/Projects/machinefile/examples/ubuntu-claude/Containerfile . 2>&1 | tail -3\r\n"]
[26.79114, "o", "--> 272a05019160\r\nSuccessfully tagged localhost/ubuntu-claude:latest\r\n272a05019160b47d6270d10a63c78c38f670a15346da624d61516994d0821422\r\n"]
[26.791449, "o", "\r\n$ # 2. Same Containerfile, now with Ducttape VM\r\n\r\n$ ducttape pull ubuntu-cloud:26.04\r\n"]
